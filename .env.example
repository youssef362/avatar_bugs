# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=-1001234567890        # your channel id (see README)

# GitHub (used as the issue store)
GITHUB_TOKEN=github_pat_xxx            # fine-grained PAT with Issues: read/write
GITHUB_REPO=your-username/your-repo    # where issues get created

# Protects the /api/reminders endpoint. Any random string.
CRON_SECRET=change-me-to-a-long-random-string

# How many days ahead to remind (default 2)
REMINDER_WINDOW_DAYS=2
